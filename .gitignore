# Ignore Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore virtual environment directories
.venv/
venv/
env/

# Ignore log files and output directories
/src/logs/
/src/output/
/output/

# Ignore media files and test artifacts, except for the assets directory
*.mp4
!/src/assets/*.mp4
*.mp3
!/src/assets/*.mp3
*.wav
!/src/assets/*.wav
*.srt

# Ignore IDE and editor specific files
.idea/
.vscode/
*.swp
